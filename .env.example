# --- Search (Tavily) ---
JORYU_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# --- Weather (Open-Meteo, key not required) ---
JORYU_WEATHER_PROVIDER=open_meteo

# --- Fetch URL ---
JORYU_FETCH_TIMEOUT=5
JORYU_FETCH_MAX_BYTES=512000

# --- MCP ---
JORYU_MCP_ENABLED=false
JORYU_MCP_URL=http://localhost:8200
